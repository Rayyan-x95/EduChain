# ── App ──────────────────────────────────────────
APP_NAME=EduLink
DEBUG=true
ENVIRONMENT=development

# ── Database (Supabase) ──────────────────────────
# Replace with your actual Supabase connection string
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.sutjmlvobmceqobgkvym:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-64
JWT_ALGORITHM=ES256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# ── S3 (MinIO) ──────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edulink

# ── Email (SMTP) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@edulink.dev

# ── Crypto ──────────────────────────────────────
KEY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef


