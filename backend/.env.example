# ─── Application ───────────────────────────────────────────
APP_NAME=EduLink
DEBUG=true
ENVIRONMENT=development

# ─── Database (Supabase) ───────────────────────────────────
# Use the connection string from Supabase Dashboard -> Settings -> Database
# Make sure to use the connection pooler (port 6543) and add +asyncpg
DATABASE_URL=postgresql+asyncpg://postgres.sutjmlvobmceqobgkvym:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── S3 / MinIO ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edulink

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@edulink.dev

# ─── Crypto ────────────────────────────────────────────────
KEY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── QR ────────────────────────────────────────────────────
QR_TOKEN_EXPIRY_MINUTES=10

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── GitHub OAuth ──────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/github/oauth/callback
