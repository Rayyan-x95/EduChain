    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "argon2": "^0.40.0",
    "bullmq": "^5.70.4",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
