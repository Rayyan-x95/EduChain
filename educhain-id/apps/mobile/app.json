{
  "expo": {
    "name": "EduChain ID",
    "slug": "educhain-id",
    "version": "0.1.0",
    "scheme": "educhain",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f12"
    },
    "ios": {
      "bundleIdentifier": "com.educhain.id",
      "supportsTablet": true
    },
    "android": {
      "package": "com.educhain.id",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0b0f12"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "646022ba-4f7a-45dc-9237-024931f68773"
      }
    }
  }
}
