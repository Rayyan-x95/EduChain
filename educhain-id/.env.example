# =============================================================================
# EduChain ID - Environment Variables (Local Development)
# =============================================================================

# Server
NODE_ENV=development
PORT=8001

# Local PostgreSQL config (via Docker Compose)
DATABASE_URL=postgresql://educhain:educhain@localhost:5432/educhain?schema=public

# Local Redis config (via Docker Compose)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=local-development-secret-123456
JWT_REFRESH_SECRET=local-development-refresh-123456

# Supabase (Auth + Storage)
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_JWT_SECRET=local-development-supabase-jwt-secret-123
SUPABASE_STORAGE_BUCKET=educhain-files

# Frontend Environments
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

EXPO_PUBLIC_API_URL=http://localhost:8001
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@educhain.dev

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
